@startuml
title Sistema de Submissao e Avaliacao de Artigos Cientificos

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle
hide empty members

skinparam nodesep 2
skinparam ranksep 4
skinparam padding 0
skinparam packagePadding 0
skinparam classPadding 0

skinparam defaultFontSize 6
skinparam classFontSize 6
skinparam classAttributeFontSize 4
skinparam classFontStyle plain

' =====================================================
' USUARIOS
' =====================================================

package "Usuarios" {
  class Usuario {
    - id: Long
    - nome: String
    - email: String
    - senha: String
    - instituicao: String
    - coordenador: boolean
    --
    + isCoordenador(): boolean
  }
}

note right of Usuario
Ha uma unica classe Usuario.

Autor, revisor e coordenador
nao sao subclasses.

Autor = Usuario ligado a Artigo por Autoria.
Revisor = Usuario ligado a Evento por MembroComite.
Coordenador = usuario.coordenador == true.
end note

' =====================================================
' EVENTO
' =====================================================

package "Evento" {
  class Evento {
    - id: Long
    - nome: String
    - cidade: String
    - dataInicio: LocalDate
    - dataFim: LocalDate
    - categoriaSubmissao: CategoriaSubmissao
    - areasTematicas: List<AreaTematica>
    - membrosComite: List<MembroComite>
    - artigos: List<Artigo>
  }

  enum CategoriaSubmissao {
    FULL_PAPER
    SHORT_PAPER
    DEMO
  }

  class AreaTematica {
    - id: long
    - nome: String
  }

  class MembroComite {
    - id: Long
    - usuario: Usuario
    - evento: Evento
    - especialidades: List<AreaTematica>
  }

  class ContextoSistema {
    - eventoAtual: Evento
    --
    + getEventoAtual(): Evento
    + definirEventoAtual(evento: Evento): void
    + limparEventoAtual(): void
  }

  class StartService {
    + iniciarNovoEvento(dados: DadosEvento): Evento
    - limparDadosDoEventoAnterior(): void
  }

  class DadosEvento {
    - nome: String
    - cidade: String
    - dataInicio: LocalDate
    - dataFim: LocalDate
    - categoriaSubmissao: CategoriaSubmissao
  }
}

Usuario "1" -- "0..*" Evento : configura se coordenador >
Evento "1" --> "1" CategoriaSubmissao : categoria do evento
Evento "1" -- "0..*" AreaTematica : areas tematicas
Evento "1" -- "0..*" MembroComite : comite
Evento "1" -- "0..*" Artigo : recebe

MembroComite "0..*" --> "1" Usuario : revisor
MembroComite "0..*" -- "0..*" AreaTematica : especialidades

ContextoSistema --> Evento : eventoAtual
StartService --> ContextoSistema
StartService --> Evento
StartService --> DadosEvento

note right of CategoriaSubmissao
CategoriaSubmissao virou enum.

Ela pertence ao evento como um todo.

O artigo nao escolhe categoria.
end note

note right of ContextoSistema
Mantem apenas o evento atual
do sistema.

O usuario autenticado nao fica
armazenado em sessao global.
Ele eh passado explicitamente
para menus e services.
end note

note right of MembroComite
MembroComite representa um Usuario
atuando como revisor em um Evento.

Isso evita criar uma classe Revisor.
end note

' =====================================================
' ARTIGO E AUTORIA
' =====================================================

package "Artigo e autoria" {
  class Artigo {
    - id: long
    - autores: List<Autoria>
    - titulo: String
    - areaTematica: List<AreaTematica>
    - resumo: String
    - evento: Evento
    - decisaoFinal: ResultadoDecisao
    - estado: EstadoArtigo
    --
    + adicionarAutor(usuario: Usuario, tipo: TipoAutoria): void
    + possuiAutor(usuario: Usuario): boolean
    + possuiAutorPrincipal(): boolean
    + distribuir(): void
    + registrarParecer(parecer: Parecer): void
    + definirDecisaoFinal(resultado: ResultadoDecisao): void
  }

  class Autoria {
    - id: Long
    - usuario: Usuario
    - tipoAutoria: TipoAutoria
    - artigo: Artigo
  }

  enum TipoAutoria {
    AUTOR_PRINCIPAL
    COAUTOR
  }

  enum ResultadoDecisao {
    ACEITO
    REJEITADO
  }
}

Artigo "1" -- "1..*" Autoria : autorias
Autoria "0..*" --> "1" Usuario : autor/coautor
Autoria --> TipoAutoria

Artigo "0..*" -- "1..*" AreaTematica : areas do artigo
Artigo --> ResultadoDecisao : decisao final

note right of Autoria
Autor nao eh classe.

Um Usuario atua como autor
quando existe uma Autoria
ligando ele a um Artigo.
end note

note right of Artigo
Artigo guarda a decisao final.

Mas a regra para calcular a decisao
fica em DecisaoService,
nao dentro de Artigo.
end note

' =====================================================
' STATE - ESTADOS DO ARTIGO
' =====================================================

package "Padrao State - Estado do Artigo" {
  interface EstadoArtigo {
    + distribuir(artigo: Artigo): void
    + registrarParecer(artigo: Artigo, parecer: Parecer): void
    + aceitar(artigo: Artigo): void
    + rejeitar(artigo: Artigo): void
    + getNome(): String
  }

  class ArtigoSubmetido {
    + distribuir(artigo: Artigo): void
    + registrarParecer(artigo: Artigo, parecer: Parecer): void
    + aceitar(artigo: Artigo): void
    + rejeitar(artigo: Artigo): void
    + getNome(): String
  }

  class ArtigoEmRevisao {
    + distribuir(artigo: Artigo): void
    + registrarParecer(artigo: Artigo, parecer: Parecer): void
    + aceitar(artigo: Artigo): void
    + rejeitar(artigo: Artigo): void
    + getNome(): String
  }

  class ArtigoAceito {
    + distribuir(artigo: Artigo): void
    + registrarParecer(artigo: Artigo, parecer: Parecer): void
    + aceitar(artigo: Artigo): void
    + rejeitar(artigo: Artigo): void
    + getNome(): String
  }

  class ArtigoRejeitado {
    + distribuir(artigo: Artigo): void
    + registrarParecer(artigo: Artigo, parecer: Parecer): void
    + aceitar(artigo: Artigo): void
    + rejeitar(artigo: Artigo): void
    + getNome(): String
  }
}

EstadoArtigo <|.. ArtigoSubmetido
EstadoArtigo <|.. ArtigoEmRevisao
EstadoArtigo <|.. ArtigoAceito
EstadoArtigo <|.. ArtigoRejeitado
Artigo --> EstadoArtigo : estadoAtual

note right of EstadoArtigo
Padrao State.

Estados do artigo:
SUBMETIDO
EM_REVISAO
ACEITO
REJEITADO

Evita if/switch espalhado
para controlar transicoes.
end note

' =====================================================
' REVISAO
' =====================================================

package "Revisao" {
  class AtribuicaoRevisao {
    - id: Long
    - artigo: Artigo
    - revisor: MembroComite
    - status: StatusRevisao
    --
    + podeAvaliar(usuario: Usuario): boolean
    + concluir(): void
  }

  enum StatusRevisao {
    PENDENTE
    CONCLUIDA
  }

  class Parecer {
    - id: Long
    - atribuicaoRevisao: AtribuicaoRevisao
    - pontosPositivos: String
    - pontosNegativos: String
    - veredito: Veredito
  }

  enum Veredito {
    REJEITADO
    FRACAMENTE_REJEITADO
    FRACAMENTE_ACEITO
    ACEITO
  }

  class RevisaoService {
    + listarRevisoesPendentes(usuario: Usuario, evento: Evento): List<AtribuicaoRevisao>
    + registrarParecer(usuario: Usuario, evento: Evento, atribuicao: AtribuicaoRevisao, parecer: Parecer): void
  }

  class DecisaoService {
    + precisaDesempate(artigo: Artigo): boolean
    + decidirResultadoFinal(artigo: Artigo): ResultadoDecisao
    + processarDecisoesDoEvento(evento: Evento): void
  }
}

Artigo "1" -- "0..*" AtribuicaoRevisao : revisoes
AtribuicaoRevisao "0..*" --> "1" MembroComite : revisor
AtribuicaoRevisao --> StatusRevisao
Parecer "0..1" --> "1" AtribuicaoRevisao : pertence a
Parecer --> Veredito

RevisaoService --> AtribuicaoRevisao
RevisaoService --> Parecer
RevisaoService --> Usuario
RevisaoService --> Evento

DecisaoService --> Artigo
DecisaoService --> ResultadoDecisao
DecisaoService --> Evento

note right of AtribuicaoRevisao
A conclusao pertence a revisao,
nao ao artigo inteiro.

Um artigo pode estar EM_REVISAO
com uma revisao concluida
e outra pendente.
end note

note right of DecisaoService
A regra de decisao fica aqui.

O coordenador aciona o processamento
das decisoes do evento, mas quem
calcula o resultado eh o service.
end note

' =====================================================
' STRATEGY - DISTRIBUICAO
' =====================================================

package "Padrao Strategy - Distribuicao de Revisores" {
  interface EstrategiaDistribuicao {
    + selecionarRevisores(artigo: Artigo, candidatos: List<MembroComite>, quantidade: int): List<MembroComite>
  }

  class DistribuicaoPorAfinidadeECarga {
    + selecionarRevisores(artigo: Artigo, candidatos: List<MembroComite>, quantidade: int): List<MembroComite>
  }

  class DistribuicaoParaDesempate {
    + selecionarRevisores(artigo: Artigo, candidatos: List<MembroComite>, quantidade: int): List<MembroComite>
  }

  class DistribuicaoService {
    - estrategia: EstrategiaDistribuicao
    --
    + alterarEstrategia(estrategia: EstrategiaDistribuicao): void
    + distribuirArtigos(evento: Evento): void
    + distribuirDesempate(artigo: Artigo, evento: Evento): void
  }
}

EstrategiaDistribuicao <|.. DistribuicaoPorAfinidadeECarga
EstrategiaDistribuicao <|.. DistribuicaoParaDesempate
DistribuicaoService --> EstrategiaDistribuicao
DistribuicaoService --> Artigo
DistribuicaoService --> MembroComite
DistribuicaoService --> Evento
DistribuicaoService --> AtribuicaoRevisao

note right of EstrategiaDistribuicao
Padrao Strategy.

Distribuicao inicial:
2 revisores por afinidade
tematica e carga.

Tambem remove revisores
com conflito de autoria.

Desempate:
1 terceiro revisor,
sem repetir avaliadores
e sem conflito de autoria.
end note

' =====================================================
' OBSERVER - EVENTOS E NOTIFICACOES
' =====================================================

package "Padrao Observer - Notificacoes" {
  interface EventoSistema {
    + getDataHora(): LocalDateTime
  }

  class ArtigoDistribuidoEvent {
    - artigo: Artigo
    - atribuicoes: List<AtribuicaoRevisao>
    - dataHora: LocalDateTime
  }

  class ResultadoPublicadoEvent {
    - artigo: Artigo
    - dataHora: LocalDateTime
  }

  interface ObservadorEvento {
    + atualizar(evento: EventoSistema): void
  }

  class PublicadorEventos {
    - observadores: List<ObservadorEvento>
    --
    + adicionar(observador: ObservadorEvento): void
    + remover(observador: ObservadorEvento): void
    + notificar(evento: EventoSistema): void
  }

  class EmailRevisorObserver {
    + atualizar(evento: EventoSistema): void
  }

  class EmailAutorObserver {
    + atualizar(evento: EventoSistema): void
  }

  class EmailService {
    + enviar(destinatario: String, assunto: String, corpo: String): void
  }
}

EventoSistema <|.. ArtigoDistribuidoEvent
EventoSistema <|.. ResultadoPublicadoEvent

ObservadorEvento <|.. EmailRevisorObserver
ObservadorEvento <|.. EmailAutorObserver

PublicadorEventos o-- ObservadorEvento
EmailRevisorObserver --> EmailService
EmailAutorObserver --> EmailService
EmailRevisorObserver --> ArtigoDistribuidoEvent
EmailAutorObserver --> ResultadoPublicadoEvent

DistribuicaoService --> PublicadorEventos : publica ArtigoDistribuidoEvent
DecisaoService --> PublicadorEventos : publica ResultadoPublicadoEvent

note right of ObservadorEvento
Padrao Observer.

O envio de emails nao fica
misturado aos services principais.

Quando algo acontece,
um evento eh publicado
e os observadores reagem.
end note

' =====================================================
' TEMPLATE METHOD - EMAILS DE RESULTADO
' =====================================================

package "Padrao Template Method - Emails de Resultado" {
  abstract class EmailResultadoTemplate {
    + gerar(artigo: Artigo): String
    # montarSaudacao(artigo: Artigo): String
    # montarMensagemPrincipal(artigo: Artigo): String
    # montarMensagemPareceres(): String
    # montarAssinatura(artigo: Artigo): String
    # montarPareceresAnonimos(artigo: Artigo): String
  }

  class EmailAceiteTemplate {
    # montarMensagemPrincipal(artigo: Artigo): String
  }

  class EmailRejeicaoTemplate {
    # montarMensagemPrincipal(artigo: Artigo): String
  }

  class EmailResultadoFactory {
    + criar(resultado: ResultadoDecisao): EmailResultadoTemplate
  }
}

EmailResultadoTemplate <|-- EmailAceiteTemplate
EmailResultadoTemplate <|-- EmailRejeicaoTemplate

EmailResultadoFactory --> EmailResultadoTemplate
EmailResultadoFactory --> ResultadoDecisao
EmailAutorObserver --> EmailResultadoFactory
EmailResultadoTemplate --> Artigo
EmailResultadoTemplate --> Parecer

note right of EmailResultadoTemplate
Padrao Template Method.

Emails de aceite e rejeicao
possuem a mesma estrutura:

saudacao
mensagem principal
assinatura
pareceres anonimos

A mensagem principal muda
conforme o resultado.
end note

' =====================================================
' FACADE - DASHBOARD DA COORDENACAO
' =====================================================

package "Padrao Facade - Dashboard da Coordenacao" {
  class DashboardService <<Facade>> {
    + gerarDashboard(evento: Evento): Dashboard
  }

  class Dashboard {
    - totalArtigosSubmetidos: Integer
    - totalRevisores: Integer
    - totalArtigosAvaliados: Integer
    - totalArtigosPendentes: Integer
    - pendencias: List<ItemPendenciaAvaliacao>
  }

  class ItemPendenciaAvaliacao {
    - tituloArtigo: String
    - nomeAvaliador: String
    - emailAvaliador: String
  }
}

DashboardService --> Dashboard
DashboardService --> Evento
DashboardService --> Artigo
DashboardService --> AtribuicaoRevisao
DashboardService --> MembroComite
Dashboard o-- ItemPendenciaAvaliacao

note right of DashboardService
Padrao Facade.

Oferece uma interface simples
para o menu da coordenacao:

gerarDashboard(evento)

Por dentro, consolida dados de
artigos, revisores e revisoes.
end note

' =====================================================
' SERVICES DE APLICACAO / UI
' =====================================================

package "Aplicacao e Terminal" {
  class AutenticacaoService {
    + login(email: String, senha: String): Usuario
  }

  class UsuarioService {
    + cadastrarUsuario(nome: String, email: String, senha: String, instituicao: String, coordenador: boolean): Usuario
  }

  class SubmissaoService {
    + submeterArtigo(usuario: Usuario, evento: Evento, dados: DadosArtigo): Artigo
    + listarArtigosDoAutor(usuario: Usuario, evento: Evento): List<Artigo>
  }

  class DadosArtigo {
    - titulo: String
    - resumo: String
    - areas: List<AreaTematica>
  }

  class ComiteService {
    + registrarMembro(usuario: Usuario, evento: Evento, areas: List<AreaTematica>): MembroComite
    + ehMembro(usuario: Usuario, evento: Evento): boolean
  }

  class MenuInicial {
    + iniciar(): void
  }

  class MenuPrincipal {
    + iniciar(usuario: Usuario, evento: Evento): void
  }

  class MenuAutor {
    + iniciar(usuario: Usuario, evento: Evento): void
  }

  class MenuRevisor {
    + iniciar(usuario: Usuario, evento: Evento): void
  }

  class MenuCoordenacao {
    + iniciar(usuario: Usuario, evento: Evento): void
  }
}

AutenticacaoService --> Usuario
UsuarioService --> Usuario

SubmissaoService --> Usuario
SubmissaoService --> Artigo
SubmissaoService --> Autoria
SubmissaoService --> Evento
SubmissaoService --> DadosArtigo

ComiteService --> Usuario
ComiteService --> Evento
ComiteService --> MembroComite
ComiteService --> AreaTematica

MenuInicial --> UsuarioService
MenuInicial --> AutenticacaoService
MenuInicial --> ContextoSistema
MenuInicial --> MenuPrincipal

MenuPrincipal --> Usuario
MenuPrincipal --> Evento
MenuPrincipal --> ComiteService
MenuPrincipal --> MenuAutor
MenuPrincipal --> MenuRevisor
MenuPrincipal --> MenuCoordenacao

MenuAutor --> SubmissaoService
MenuRevisor --> RevisaoService
MenuCoordenacao --> StartService
MenuCoordenacao --> ComiteService
MenuCoordenacao --> DistribuicaoService
MenuCoordenacao --> DashboardService
MenuCoordenacao --> DecisaoService

note right of MenuPrincipal
Nao existe SessaoUsuario.

Depois do login, o Usuario autenticado
e o Evento atual sao passados
explicitamente para os menus.

Area de Autor:
todo usuario cadastrado.

Area de Revisor:
se existe MembroComite.

Area de Coordenacao:
se usuario.coordenador == true.
end note

note right of MenuCoordenacao
O coordenador pode:

iniciar novo evento
registrar membros do comite
distribuir artigos
processar decisoes finais
visualizar dashboard
end note

@enduml
